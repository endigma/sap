{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "separate-pull-requests": true,
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance"
    },
    {
      "type": "revert",
      "section": "Reverts"
    },
    {
      "type": "docs",
      "section": "Documentation"
    }
  ],
  "packages": {
    ".": {
      "component": "sap",
      "include-component-in-tag": false,
      "changelog-path": "CHANGELOG.md"
    },
    "viewer/tui": {
      "component": "viewer/tui",
      "include-component-in-tag": true,
      "tag-separator": "/",
      "changelog-path": "viewer/tui/CHANGELOG.md"
    },
    "viewer/web": {
      "component": "viewer/web",
      "include-component-in-tag": true,
      "tag-separator": "/",
      "changelog-path": "viewer/web/CHANGELOG.md"
    }
  }
}
